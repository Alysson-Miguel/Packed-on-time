# Copie para .env (local) e/ou configure como Environment Variables no projeto Vercel.
# Valores vêm do client_email e private_key do JSON da Service Account do GCP.
# A planilha (1tYIoqJZU-LzCwGnoRG5ScTLDq2sR6Qo9UA5wcOol204) precisa estar compartilhada
# com esse e-mail (acesso de Leitor). Usado apenas por api/refresh-cache.js (job em
# background); api/sheet-data.js (consumido pelo painel) não toca a planilha.

GOOGLE_SERVICE_ACCOUNT_EMAIL=bot-production@project-kpi-460318.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"

# String aleatória qualquer (ex: gere com `openssl rand -hex 32`). Protege o
# /api/refresh-cache para que só o Cron da Vercel (ou você manualmente) possa acioná-lo.
# A Vercel injeta esse valor automaticamente como header Authorization nas chamadas de cron.
CRON_SECRET=defina-uma-string-aleatoria-aqui

# Gerado automaticamente pela Vercel ao habilitar Storage → Blob no projeto.
# Para testar localmente, rode `vercel env pull .env` depois de habilitar o Blob,
# ou copie o token manualmente do dashboard da Vercel.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
